# ─── App ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
ALLOWED_ORIGINS=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────
# PostgreSQL 16 connection URL
DATABASE_URL=postgresql://markcomm:markcomm_local_dev@localhost:5432/markcomm_dev

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://:markcomm_local_dev@localhost:6379

# ─── JWT Secrets (generate with: node -e "require('crypto').randomBytes(64).toString('hex')")
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_HEX_SECRET
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Cookie ───────────────────────────────────────────────────────
COOKIE_SECRET=REPLACE_WITH_32_PLUS_CHAR_SECRET

# ─── AWS ──────────────────────────────────────────────────────────
# AWS region: ap-southeast-1 (Singapore) — closest to Sri Lanka
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=markcomm-dev-assets
S3_PUBLIC_URL=https://markcomm-dev-assets.s3.ap-southeast-1.amazonaws.com
CLOUDFRONT_URL=

# ─── Email ────────────────────────────────────────────────────────
# Amazon SES — use MailHog locally: smtp://localhost:1025
SES_FROM_EMAIL=noreply@markcomm.lk

# ─── Payment Gateways (Sri Lanka) ─────────────────────────────────
# PayHere — Primary Sri Lankan payment gateway (payhere.lk)
# Register at: https://www.payhere.lk/sign-up
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_SANDBOX=true

# Dialog Genie — Sri Lankan digital wallet
GENIE_API_KEY=
GENIE_MERCHANT_CODE=

# FriMi — Sri Lankan digital wallet (Nations Trust Bank)
FRIMI_API_KEY=
FRIMI_MERCHANT_ID=

# Stripe — International cards, Apple Pay, Google Pay
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ─── Elasticsearch ────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_API_KEY=

# ─── Tax (Sri Lanka) ──────────────────────────────────────────────
# Sri Lanka: VAT 18% + NBT (Nation Building Tax)
LK_VAT_RATE=0.18
LK_NBT_RATE=0.02
LK_DEFAULT_CURRENCY=LKR

# ─── Email SMTP (SES in prod, MailHog in dev) ─────────────────────
# Dev: MailHog runs on smtp://localhost:1025 — leave empty below
# Prod: use AWS SES SMTP endpoint credentials
AWS_SES_SMTP_USER=
AWS_SES_SMTP_PASS=

# ─── App URL ──────────────────────────────────────────────────────
# Frontend URL — used in email links and PayHere return URLs
APP_URL=http://localhost:3000
