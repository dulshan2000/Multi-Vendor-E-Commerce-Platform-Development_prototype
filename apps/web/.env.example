# ─── Next.js Frontend Environment ────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MarkComm

# ─── Payment (PayHere public keys are safe to expose client-side)
NEXT_PUBLIC_PAYHERE_MERCHANT_ID=
NEXT_PUBLIC_PAYHERE_SANDBOX=true
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# ─── Analytics & Monitoring
NEXT_PUBLIC_SENTRY_DSN=

# ─── Google Maps (address validation & autocomplete)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── Currency
NEXT_PUBLIC_DEFAULT_CURRENCY=LKR
NEXT_PUBLIC_DEFAULT_LOCALE=en-LK
