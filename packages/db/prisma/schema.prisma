// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  SUPER_ADMIN
  PLATFORM_ADMIN
  VENDOR_OWNER
  VENDOR_STAFF
  CUSTOMER
  GUEST
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum VendorStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  SUSPENDED
  REJECTED
}

enum VendorOnboardingStep {
  BUSINESS_REGISTRATION
  DOCUMENT_UPLOAD
  PAYOUT_SETUP
  STORE_SETUP
  SHIPPING_CONFIG
  POLICY_AGREEMENT
  ADMIN_REVIEW
  LIVE
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_CONFIRMED
  VENDOR_ACCEPTED
  PROCESSING
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURN_REQUESTED
  RETURN_APPROVED
  RETURN_REJECTED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum CommissionType {
  PERCENTAGE
  FIXED
  TIERED
}

enum LedgerEntryType {
  ORDER_REVENUE
  COMMISSION_DEDUCTION
  PAYOUT_DISBURSEMENT
  REFUND_DEDUCTION
  ADJUSTMENT_CREDIT
  ADJUSTMENT_DEBIT
}

enum CouponType {
  PERCENTAGE_DISCOUNT
  FIXED_DISCOUNT
  FREE_SHIPPING
  BUY_X_GET_Y
  BUNDLE
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  PICKUP_SCHEDULED
  RECEIVED
  REFUND_INITIATED
  COMPLETED
}

// ============================================================
// USERS & IDENTITY
// ============================================================

model User {
  id                String     @id @default(cuid())
  email             String     @unique
  firstName         String?
  lastName          String?
  passwordHash      String?
  role              UserRole   @default(CUSTOMER)
  status            UserStatus @default(PENDING_VERIFICATION)
  emailVerifiedAt   DateTime?
  twoFactorEnabled  Boolean    @default(false)
  twoFactorSecret   String?
  lastLoginAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Relations
  vendorProfile     VendorProfile?
  customerProfile   CustomerProfile?
  orders            Order[]
  auditLogs         AuditLog[]
  oauthAccounts     OAuthAccount[]
  sessions          UserSession[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("users")
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@map("user_sessions")
}

model OAuthAccount {
  id             String   @id @default(cuid())
  userId         String
  provider       String   // "google" | "facebook"
  providerUserId String
  accessToken    String?
  refreshToken   String?
  expiresAt      DateTime?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

// ============================================================
// VENDOR
// ============================================================

model VendorProfile {
  id                     String       @id @default(cuid())
  userId                 String       @unique
  businessName           String
  businessType           String?      // SOLE_PROPRIETORSHIP | PARTNERSHIP | PVT_LTD | PLC | NGO
  businessRegNo          String?
  taxNumber              String?      // Sri Lanka TIN
  phone                  String?      // +94XXXXXXXXX format
  website                String?
  addressLine1           String?
  addressLine2           String?
  city                   String?
  district               String?
  province               String?      // SriLankaProvince enum (stored as string)
  postalCode             String?
  status                 VendorStatus @default(PENDING)
  onboardingStep         String       @default("business_info")
  onboardingCompletedAt  DateTime?
  submittedForReviewAt   DateTime?
  policiesAcceptedAt     DateTime?
  approvedAt             DateTime?
  approvedByAdminId      String?
  rejectionReason        String?
  suspensionReason       String?
  suspendedUntil         DateTime?
  shippingConfig         Json?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  // Relations
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  storefront       VendorStorefront?
  products         Product[]
  documents        VendorDocument[]
  payoutAccounts   PayoutAccount[]
  commissionRules  CommissionRule[]
  ledgerEntries    LedgerEntry[]
  payoutRequests   PayoutRequest[]
  orderItems       OrderItem[]
  staffMembers     VendorStaff[]
  staffInvitations VendorStaffInvitation[]

  @@index([status])
  @@map("vendor_profiles")
}

model VendorStorefront {
  id              String   @id @default(cuid())
  vendorId        String   @unique
  slug            String   @unique
  displayName     String
  description     String?
  tagline         String?
  bannerS3Key     String?
  logoS3Key       String?
  primaryColor    String?
  accentColor     String?
  socialLinks     Json?    // { instagram, facebook, website }
  categories      String[] // category IDs vendor sells in
  featuredProducts String[]
  metaTitle       String?
  metaDescription String?
  updatedAt       DateTime @updatedAt

  vendor VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([slug])
  @@map("vendor_storefronts")
}

model VendorDocument {
  id           String   @id @default(cuid())
  vendorId     String
  documentType String   // BUSINESS_REGISTRATION | NATIONAL_ID | TAX_CERTIFICATE | BANK_STATEMENT
  fileName     String
  s3Key        String
  mimeType     String
  status       String   @default("PENDING_REVIEW") // PENDING_REVIEW | APPROVED | REJECTED
  reviewNote   String?
  reviewedAt   DateTime?
  uploadedAt   DateTime @default(now())

  vendor VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@map("vendor_documents")
}

model VendorStaffInvitation {
  id             String    @id @default(cuid())
  vendorId       String
  invitedEmail   String
  invitedByUserId String
  permissions    Json      // { manageOrders, manageCatalog, viewAnalytics, manageStaff }
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  vendor VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([invitedEmail])
  @@map("vendor_staff_invitations")
}

model VendorStaff {
  id          String   @id @default(cuid())
  vendorId    String
  userId      String
  permissions Json     // { manageOrders, manageCatalog, viewAnalytics, manageStaff }
  invitedAt   DateTime @default(now())
  acceptedAt  DateTime?

  vendor VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, userId])
  @@map("vendor_staff")
}

model PayoutAccount {
  id            String    @id @default(cuid())
  vendorId      String    @unique  // One active payout account per vendor
  accountType   String              // BANK | PAYPAL
  accountName   String
  bankName      String?             // Sri Lankan bank enum stored as string
  branchCode    String?
  accountNumber String?             // encrypted at rest
  paypalEmail   String?
  isVerified    Boolean   @default(false)
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  vendor VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("payout_accounts")
}

model CommissionRule {
  id             String         @id @default(cuid())
  vendorId       String?        // null = platform default
  type           CommissionType
  rate           Decimal        @db.Decimal(5, 4)  // e.g., 0.1000 = 10%
  fixedAmount    Decimal?       @db.Decimal(12, 2) // LKR fixed amount
  thresholdMin   Decimal?       @db.Decimal(12, 2)
  thresholdMax   Decimal?       @db.Decimal(12, 2)
  currency       String         @default("LKR")   // Sri Lanka default
  effectiveFrom  DateTime       @default(now())
  effectiveTo    DateTime?
  createdAt      DateTime       @default(now())

  vendor VendorProfile? @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@map("commission_rules")
}

// ============================================================
// CUSTOMER
// ============================================================

model CustomerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  firstName   String?
  lastName    String?
  phone       String?
  dateOfBirth DateTime?
  avatarUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  addresses      Address[]
  wishlists      Wishlist[]
  loyaltyAccount LoyaltyAccount?
  carts          Cart[]

  @@map("customer_profiles")
}

model Address {
  id           String   @id @default(cuid())
  customerId   String
  label        String?  // "Home", "Work", etc.
  firstName    String
  lastName     String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String?
  postalCode   String
  countryCode  String
  phone        String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())

  customer CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@index([customerId])
  @@map("addresses")
}

model Wishlist {
  id         String         @id @default(cuid())
  customerId String
  name       String         @default("My Wishlist")
  isPublic   Boolean        @default(false)
  shareToken String?        @unique
  createdAt  DateTime       @default(now())

  customer CustomerProfile  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  items    WishlistItem[]

  @@index([customerId])
  @@map("wishlists")
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  variantId  String
  addedAt    DateTime @default(now())

  wishlist Wishlist        @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  variant  ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, variantId])
  @@map("wishlist_items")
}

model LoyaltyAccount {
  id             String      @id @default(cuid())
  customerId     String      @unique
  points         Int         @default(0)
  lifetimePoints Int         @default(0)
  tier           LoyaltyTier @default(BRONZE)
  tierUpdatedAt  DateTime    @default(now())
  pointsExpiryAt DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  customer CustomerProfile      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  events   LoyaltyEvent[]

  @@map("loyalty_accounts")
}

model LoyaltyEvent {
  id            String   @id @default(cuid())
  accountId     String
  type          String   // "EARN" | "REDEEM" | "EXPIRE" | "ADJUSTMENT"
  points        Int
  balanceAfter  Int
  referenceId   String?
  referenceType String?  // "ORDER" | "PROMOTION" | "MANUAL"
  description   String?
  createdAt     DateTime @default(now())

  account LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("loyalty_events")
}

// ============================================================
// CATALOG
// ============================================================

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  imageUrl    String?
  parentId    String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  metaTitle   String?
  metaDescription String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products ProductCategory[]

  @@index([parentId])
  @@index([slug])
  @@map("categories")
}

model Product {
  id          String        @id @default(cuid())
  vendorId    String
  title       String
  description String?
  status      ProductStatus @default(DRAFT)
  tags        String[]
  metadata    Json?         // Flexible attributes (fabric, fit, occasion, etc.)
  rating      Decimal       @default(0) @db.Decimal(3, 2)
  reviewCount Int           @default(0)
  salesCount  Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  vendor     VendorProfile     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  variants   ProductVariant[]
  images     ProductImage[]
  categories ProductCategory[]
  reviews    ProductReview[]

  @@index([vendorId])
  @@index([status])
  @@index([tags])
  @@map("products")
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  sku           String   @unique
  size          String?
  color         String?
  material      String?
  price         Decimal  @db.Decimal(10, 2)
  comparePrice  Decimal? @db.Decimal(10, 2)
  weight        Decimal? @db.Decimal(8, 3) // kg
  dimensions    Json?    // { length, width, height }
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product       Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory     InventoryRecord?
  orderItems    OrderItem[]
  cartItems     CartItem[]
  wishlistItems WishlistItem[]

  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  s3Key     String
  url       String
  altText   String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model ProductCategory {
  productId  String
  categoryId String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@map("product_categories")
}

model InventoryRecord {
  id                  String   @id @default(cuid())
  variantId           String   @unique
  quantity            Int      @default(0)
  reservedQuantity    Int      @default(0) // soft-locked by carts
  lowStockThreshold   Int      @default(5)
  warehouseLocation   String?
  lastRestockedAt     DateTime?
  updatedAt           DateTime @updatedAt

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@map("inventory_records")
}

model ProductReview {
  id         String   @id @default(cuid())
  productId  String
  userId     String
  orderId    String?
  rating     Int      // 1-5
  title      String?
  body       String?
  isVerified Boolean  @default(false) // purchased this item
  helpfulCount Int    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, userId, orderId])
  @@index([productId])
  @@index([userId])
  @@map("product_reviews")
}

// ============================================================
// CART
// ============================================================

model Cart {
  id           String    @id @default(cuid())
  customerId   String?   // null for guest carts
  sessionToken String?   @unique // for guest carts
  currency     String    @default("USD")
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  customer CustomerProfile? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items    CartItem[]

  @@index([customerId])
  @@map("carts")
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  variantId String
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2) // snapshot at time of add
  addedAt   DateTime @default(now())

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
  @@map("cart_items")
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id               String      @id @default(cuid())
  orderNumber      String      @unique
  customerId       String
  addressId        String?
  status           OrderStatus @default(PENDING_PAYMENT)
  currency         String      @default("USD")
  subtotal         Decimal     @db.Decimal(12, 2)
  discountTotal    Decimal     @default(0) @db.Decimal(12, 2)
  taxTotal         Decimal     @default(0) @db.Decimal(12, 2)
  shippingTotal    Decimal     @default(0) @db.Decimal(12, 2)
  grandTotal       Decimal     @db.Decimal(12, 2)
  couponCode       String?
  notes            String?
  cancelledAt      DateTime?
  cancelledReason  String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  customer  User             @relation(fields: [customerId], references: [id])
  address   Address?         @relation(fields: [addressId], references: [id])
  items     OrderItem[]
  payments  Payment[]
  shipments OrderShipment[]
  returns   ReturnRequest[]

  @@index([customerId])
  @@index([status])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id                  String   @id @default(cuid())
  orderId             String
  variantId           String
  vendorId            String
  quantity            Int
  unitPrice           Decimal  @db.Decimal(10, 2)
  discountAmount      Decimal  @default(0) @db.Decimal(10, 2)
  taxAmount           Decimal  @default(0) @db.Decimal(10, 2)
  subtotal            Decimal  @db.Decimal(10, 2)
  vendorPayoutAmount  Decimal  @db.Decimal(10, 2)
  commissionAmount    Decimal  @db.Decimal(10, 2)
  createdAt           DateTime @default(now())

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])
  vendor  VendorProfile  @relation(fields: [vendorId], references: [id])

  @@index([orderId])
  @@index([vendorId])
  @@map("order_items")
}

model Payment {
  id               String        @id @default(cuid())
  orderId          String
  gateway          String        // "stripe" | "payhere" | "paypal"
  gatewayPaymentId String?       @unique
  amount           Decimal       @db.Decimal(12, 2)
  currency         String
  status           PaymentStatus @default(PENDING)
  method           String?       // "card" | "apple_pay" | "google_pay"
  metadata         Json?
  failureReason    String?
  paidAt           DateTime?
  refundedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([gatewayPaymentId])
  @@map("payments")
}

// ============================================================
// SHIPMENTS & TRACKING
// ============================================================

model OrderShipment {
  id             String   @id @default(cuid())
  orderId        String
  vendorId       String
  carrier        String   // "DHL" | "FEDEX" | "UPS" | "LOCAL"
  trackingNumber String?
  labelUrl       String?
  estimatedDelivery DateTime?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  order  Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events ShipmentTrackingEvent[]

  @@index([orderId])
  @@index([trackingNumber])
  @@map("order_shipments")
}

model ShipmentTrackingEvent {
  id          String   @id @default(cuid())
  shipmentId  String
  status      String
  description String?
  location    String?
  timestamp   DateTime
  rawPayload  Json?
  createdAt   DateTime @default(now())

  shipment OrderShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@map("shipment_tracking_events")
}

// ============================================================
// RETURNS
// ============================================================

model ReturnRequest {
  id           String       @id @default(cuid())
  orderId      String
  customerId   String
  status       ReturnStatus @default(REQUESTED)
  reason       String
  description  String?
  photoUrls    String[]
  refundAmount Decimal?     @db.Decimal(10, 2)
  approvedAt   DateTime?
  rejectedAt   DateTime?
  receivedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([customerId])
  @@map("return_requests")
}

// ============================================================
// FINANCIAL (Append-only Ledger)
// ============================================================

model LedgerEntry {
  id            String          @id @default(cuid())
  vendorId      String
  type          LedgerEntryType
  amount        Decimal         @db.Decimal(12, 2)
  currency      String          @default("USD")
  referenceId   String?
  referenceType String?         // "ORDER" | "PAYOUT" | "REFUND" | "ADJUSTMENT"
  description   String?
  createdAt     DateTime        @default(now()) // NEVER update this

  vendor VendorProfile @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([referenceId])
  @@index([createdAt])
  @@map("ledger_entries")
}

model PayoutRequest {
  id               String      @id @default(cuid())
  vendorId         String
  payoutAccountId  String?
  amount           Decimal     @db.Decimal(12, 2)
  currency         String      @default("USD")
  status           PayoutStatus @default(PENDING)
  scheduledAt      DateTime?
  processedAt      DateTime?
  gatewayReference String?
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  vendor VendorProfile @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@index([status])
  @@map("payout_requests")
}

// ============================================================
// MARKETING
// ============================================================

model Coupon {
  id               String     @id @default(cuid())
  code             String     @unique
  type             CouponType
  discountValue    Decimal    @db.Decimal(10, 2)
  minimumOrderAmount Decimal? @db.Decimal(10, 2)
  maximumDiscountAmount Decimal? @db.Decimal(10, 2)
  usageLimit       Int?
  usageCount       Int        @default(0)
  perUserLimit     Int?
  targetType       String?    // "ALL" | "SEGMENT" | "FIRST_TIME" | "VENDOR" | "CATEGORY"
  targetIds        String[]   // vendor IDs, category IDs etc.
  validFrom        DateTime
  validTo          DateTime
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())

  @@index([code])
  @@index([isActive])
  @@map("coupons")
}

model AbandonedCart {
  id           String   @id @default(cuid())
  userId       String
  cartSnapshot Json     // snapshot of cart at abandonment
  emailSent1At DateTime?
  emailSent2At DateTime?
  emailSent3At DateTime?
  recoveredAt  DateTime?
  recoveredOrderId String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("abandoned_carts")
}

// ============================================================
// ADMIN & AUDIT
// ============================================================

model AuditLog {
  id           String   @id @default(cuid())
  userId       String
  action       String   // e.g., "VENDOR_APPROVED", "USER_SUSPENDED", "ORDER_CANCELLED"
  targetType   String?  // "VENDOR" | "USER" | "ORDER" | "PRODUCT"
  targetId     String?
  metadata     Json?    // before/after state
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

model CmsPage {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  content     String   // Rich text (HTML)
  metaTitle   String?
  metaDescription String?
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@map("cms_pages")
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("system_config")
}
